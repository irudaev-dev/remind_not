# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (send /start to the bot after launch to get it)
OWNER_CHAT_ID=123456789

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your timezone (e.g. Europe/Amsterdam, Europe/Moscow, UTC)
TIMEZONE=Europe/Amsterdam

# Google Calendar OAuth (optional)
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
